# Engine Strict - enforce Node.js version from package.json
engine-strict=true

# Save Exact - lock exact versions (no ^ or ~)
save-exact=false

# Audit - security checks during install
audit=true
audit-level=moderate

# Package Lock - ensure consistent installs
package-lock=true

# Legacy Peer Dependencies - handle peer dependency conflicts
# Set to true if you encounter peer dependency issues
legacy-peer-deps=false

# Progress - show progress bar during install
progress=true

# Loglevel - control output verbosity (silent|error|warn|notice|http|timing|info|verbose|silly)
loglevel=notice

# Fund Messages - show funding messages after install
fund=false

# Prefer Offline - use cache when possible
prefer-offline=false

# Registry (default npm registry)
registry=https://registry.npmjs.org/
